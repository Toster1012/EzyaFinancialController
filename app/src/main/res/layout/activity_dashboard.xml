<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground">

    <TextView
        android:id="@+id/daysRemainingTextView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#FFDD2D"
        android:textSize="13sp"
        android:textStyle="bold"
        android:layout_marginTop="24dp"
        android:layout_marginStart="20dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/historyButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/history"
        android:textColor="#8A8A8A"
        android:textSize="13sp"
        android:paddingVertical="4dp"
        android:layout_marginTop="22dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toEndOf="@id/daysRemainingTextView"
        app:layout_constraintEnd_toStartOf="@id/settingsButton"
        app:layout_constraintHorizontal_bias="0.5"/>

    <TextView
        android:id="@+id/settingsButton"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:text="⚙"
        android:textColor="#8A8A8A"
        android:textSize="20sp"
        android:gravity="center"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="4dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toStartOf="@id/closeButton" />

    <TextView
        android:id="@+id/closeButton"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:text="✕"
        android:textColor="?android:attr/textColorPrimary"
        android:textSize="20sp"
        android:gravity="center"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginHorizontal="20dp"
        android:background="@color/surface"
        app:tabSelectedTextColor="#FFDD2D"
        app:tabTextColor="#8A8A8A"
        app:tabIndicatorColor="#FFDD2D"
        app:tabRippleColor="@android:color/transparent"
        app:layout_constraintTop_toBottomOf="@id/daysRemainingTextView"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPager"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tabLayout"
        app:layout_constraintBottom_toTopOf="@id/addTransactionButton"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/addTransactionButton"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:text="@string/add_transaction"
        android:textColor="#0A0A0A"
        android:textStyle="bold"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="8dp"
        app:backgroundTint="#FFDD2D"
        app:cornerRadius="14dp"
        app:elevation="0dp"
        app:layout_constraintBottom_toTopOf="@id/endPeriodTestButton"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/endPeriodTestButton"
        android:layout_width="0dp"
        android:layout_height="44dp"
        android:text="@string/end_period"
        android:textColor="?android:attr/textColorPrimary"
        android:textSize="13sp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="16dp"
        app:backgroundTint="@color/surface"
        app:cornerRadius="14dp"
        app:elevation="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>