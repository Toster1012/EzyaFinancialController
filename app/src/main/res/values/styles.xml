<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="DarkAlertDialog" parent="Theme.MaterialComponents.Dialog.Alert">
        <item name="colorSurface">#1A1A1A</item>
        <item name="colorOnSurface">#FFFFFF</item>
        <item name="buttonBarPositiveButtonStyle">@style/YellowButton</item>
        <item name="buttonBarNegativeButtonStyle">@style/GrayButton</item>
    </style>

    <style name="YellowButton" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">#FFDD2D</item>
    </style>

    <style name="GrayButton" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">#8A8A8A</item>
    </style>
</resources>